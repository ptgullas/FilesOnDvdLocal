@page "/"
@using MediaFilesOnDvd.Services.Dtos
@inject PerformerService PerformerService
@inject MediaFileService MediaFileService
@inject PathResolverService PathResolver
@inject IConfiguration Config
@inject NavigationManager Nav

<div class="dashboard">
    <section class="carousel-section">
        <h2 class="section-title">
            Explore Performers (@(_randomPerformers?.Count ?? 0) loaded)
            <i class="fas fa-sync-alt ms-2 text-muted" style="cursor:pointer; font-size: 0.6em;" @onclick="RefreshPerformers" title="Refresh Performers"></i>
        </h2>
        <div class="carousel-container">
            @if (_randomPerformers == null)
            {
                <p>Loading performers...</p>
            }
            else
            {
                <div class="carousel-track">
                    @if (_randomPerformers.Count == 0) { <p>No performers found in DB.</p> }
                    @foreach (var performer in _randomPerformers)
                    {
                        try {
                            <div class="dash-carousel-item performer-card" @onclick="() => OpenPerformerModal(performer.Id)">
                                <div class="image-wrapper">
                                    @if (!string.IsNullOrEmpty(performer.GalleryPhotoUrl))
                                    {
                                        <img src="@PathResolver.GetImageAsBase64(PathResolver.GetPerformerGalleryPath(performer.GalleryPhotoUrl))" alt="@performer.Name" />
                                    }
                                    else if (!string.IsNullOrEmpty(performer.HeadshotUrl))
                                    {
                                        <img src="@PathResolver.GetImageAsBase64(PathResolver.GetPerformerHeadshotPath(performer.HeadshotUrl))" alt="@performer.Name" />
                                    }
                                    else
                                    {
                                        <div class="placeholder-img"><i class="fas fa-user fa-3x"></i></div>
                                    }
                                    <div class="item-overlay">
                                        <span class="item-name">@performer.Name</span>
                                    </div>
                                </div>
                            </div>
                        }
                        catch (Exception ex)
                        {
                            <div style="background: black; color: yellow; padding: 10px; margin: 10px; font-family: monospace;">
                                EXCEPTION: @ex.Message<br/>
                                TYPE: @ex.GetType().Name
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </section>

    <section class="carousel-section">
        <h2 class="section-title">
            Recent Media (@(_randomFiles?.Count ?? 0) loaded)
            <i class="fas fa-sync-alt ms-2 text-muted" style="cursor:pointer; font-size: 0.6em;" @onclick="RefreshMedia" title="Refresh Media"></i>
        </h2>
        <div class="carousel-container">
            @if (_randomFiles == null)
            {
                <p>Loading media...</p>
            }
            else
            {
                <div class="carousel-track">
                    @if (_randomFiles.Count == 0) { <p>No media files found in DB.</p> }
                    @foreach (var file in _randomFiles)
                    {
                        try {
                            <div class="dash-carousel-item media-card" @onclick="() => OpenMediaFileModal(file.Id)">
                                <div class="image-wrapper">
                                    @if (file.Screenshots != null && file.Screenshots.Any())
                                    {
                                        <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(file.Screenshots.FirstOrDefault()?.Url ?? ""))" alt="@file.Name" />
                                    }
                                    else
                                    {
                                        <div class="placeholder-img"><i class="fas fa-file-video fa-3x"></i></div>
                                    }
                                    <div class="item-overlay">
                                        <span class="item-name">@file.Name</span>
                                    </div>
                                </div>
                            </div>
                        }
                        catch (Exception ex)
                        {
                            <div style="background: black; color: yellow; padding: 10px; margin: 10px; font-family: monospace;">
                                EXCEPTION: @ex.Message<br/>
                                TYPE: @ex.GetType().Name
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </section>
</div>

<MediaFilesOnDvd.UI.Shared.MediaFileModal @ref="_mediaFileModal" />

<MediaFilesOnDvd.UI.Shared.PerformerModal @ref="_performerModal" />

@code {
    private List<PerformerWithGalleryDto>? _randomPerformers;
    private List<MediaFile>? _randomFiles;

    private MediaFilesOnDvd.UI.Shared.PerformerModal? _performerModal;
    private MediaFilesOnDvd.UI.Shared.MediaFileModal? _mediaFileModal;

    protected override void OnInitialized()
    {
        RefreshPerformers();
        RefreshMedia();
    }

    private void RefreshPerformers()
    {
        // Get 10 random performers
        _randomPerformers = PerformerService.GetWithGalleries()
            .OrderBy(x => Guid.NewGuid())
            .Take(10)
            .ToList();

        // show a specific performer with a known gallery for testing purposes
        // _randomPerformers[0] = PerformerService.GetWithGalleries().FirstOrDefault(p => p.Id == 2021);
    }
    
    private void RefreshMedia()
    {
        // Get 10 random files
        _randomFiles = MediaFileService.Get()
            .Where(mf => mf.FileGenreId == 3)
            .OrderBy(x => Guid.NewGuid())
            .Take(10)
            .ToList();
    }

    private void NavigateToPerformer(int id)
    {
        Nav.NavigateTo($"/performers/{id}");
    }

    private void OpenPerformerModal(int id)
    {
        _performerModal?.Open(id);
    }

    private void OpenMediaFileModal(int id)
    {
        _mediaFileModal?.Open(id);
    }
}
