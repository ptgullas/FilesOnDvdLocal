@page "/performers"
@page "/performers/{Id:int}"
@using MediaFilesOnDvd.Services.Dtos
@inject PerformerService PerformerService
@inject PathResolverService PathResolver
@inject NavigationManager Nav
@inject IJSRuntime JS

<SectionContent SectionName="header-center">
    <div class="d-flex align-items-center w-100" style="max-width: 600px;">
        <div class="search-container flex-grow-1 me-3">
            <i class="fas fa-search search-icon"></i>
            <input type="text" placeholder="Search / filter performers..." class="search-input w-100" @bind="_searchTerm" @bind:event="oninput" />
        </div>
        <button class="btn btn-primary text-nowrap" @onclick="CreateNewPerformer">
            <i class="fas fa-plus"></i> New Performer
        </button>
    </div>
</SectionContent>

<div class="performer-browse">
    <!-- Left Panel: Master List -->
    <aside class="performer-list-panel">
        <div class="search-box">
            <i class="fas fa-filter"></i>
            <input type="text" placeholder="Filter performers..." @bind="_searchTerm" @bind:event="oninput" />
        </div>
        <div class="performer-scroll-list">
            <Virtualize Items="FilteredPerformers" Context="performer" OverscanCount="10">
                <div class="performer-list-item @(performer.Id == _selectedPerformer?.Id ? "selected" : "")" 
                @onclick="() => SelectPerformer(performer.Id)">
                    <div class="performer-thumb">
                        @if (!string.IsNullOrEmpty(performer.HeadshotUrl))
                        {
                            <img src="@PathResolver.GetImageAsBase64(PathResolver.GetPerformerHeadshotPath(performer.HeadshotUrl))" alt="" />
                        }
                        else
                        {
                            <i class="fas fa-user"></i>
                        }
                    </div>
                    <span class="performer-name">@performer.Name</span>
                </div>
            </Virtualize>
        </div>
    </aside>

    <!-- Center Panel: Detail -->
    <main class="performer-detail-panel">
        @if (_selectedPerformer == null && !_isEditing)
        {
            <div class="empty-state">
                <i class="fas fa-users fa-4x"></i>
                <h3>Select a performer to view details</h3>
            </div>
        }
        else
        {
            <div class="detail-header">
                @if (!_isEditing && _selectedPerformer != null)
                {
                    <div class="headshot-large">
                        @if (!string.IsNullOrEmpty(_selectedPerformer.HeadshotUrl))
                        {
                            <img src="@PathResolver.GetImageAsBase64(PathResolver.GetPerformerHeadshotPath(_selectedPerformer.HeadshotUrl))" alt="@_selectedPerformer.Name" />
                        }
                        else
                        {
                            <div class="placeholder-large"><i class="fas fa-user fa-5x"></i></div>
                        }
                    </div>
                    <div class="header-info">
                        <div class="d-flex justify-content-between align-items-center w-100">
                            <h1>@_selectedPerformer.Name</h1>
                            <button class="btn btn-outline-light btn-sm" @onclick="EnterEditMode">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        </div>
                        <p class="aliases">Aliases: @(_selectedPerformer.Aliases.Any() ? string.Join(", ", _selectedPerformer.Aliases) : "--")</p>
                        <div class="gallery-preview">
                            <span class="badge">Gallery coming soon</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="edit-form w-100 p-3" style="background: rgba(255,255,255,0.05); border-radius: 8px;">
                        <h3>@(_editModel.Id == 0 ? "New Performer" : "Edit Performer")</h3>
                        <div class="form-group mb-2">
                            <label>Name</label>
                            <input class="form-control" @bind="_editModel.Name" />
                        </div>
                        <div class="form-group mb-2">
                            <label>Aliases</label>
                            <div class="d-flex flex-wrap mb-2">
                                @foreach(var alias in _editModel.Aliases) {
                                    <span class="badge bg-secondary me-2 mb-2 p-2" style="font-size: 0.9em;">
                                        @alias 
                                        <i class="fas fa-times ms-2 text-danger" style="cursor:pointer;" @onclick="() => RemoveAlias(alias)"></i>
                                    </span>
                                }
                            </div>
                            <div class="d-flex">
                                <input class="form-control me-2" @bind="_newAlias" placeholder="Add new alias..." />
                                <button class="btn btn-outline-light" @onclick="AddAlias">Add</button>
                            </div>
                        </div>
                        <div class="form-group mb-2">
                            <label>Add Headshot</label>
                            <InputFile OnChange="UploadHeadshot" accept="image/*" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label>Add Gallery Photo</label>
                            <InputFile OnChange="UploadGalleryPhoto" accept="image/*" class="form-control" />
                        </div>
                        <div>
                            <button class="btn btn-primary" @onclick="SaveChanges">Save</button>
                            <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </div>
                }
            </div>

            @if (_selectedPerformer != null)
            {
                <div class="media-list-section">
                    <h3>Appears In (@(_selectedPerformer.MediaFiles.Count) files)</h3>
                    <div class="media-grid">
                        @foreach (var file in _selectedPerformer.MediaFiles)
                        {
                            <div class="media-item" @onclick="() => ViewMediaFile(file.Id)">
                                <div class="media-thumb">
                                    @if (!string.IsNullOrEmpty(file.ScreenshotUrl))
                                    {
                                        <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(file.ScreenshotUrl))" alt="" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-file-video"></i>
                                    }
                                </div>
                                <div class="media-info">
                                    <span class="file-name">@file.Name</span>
                                    <span class="disc-name">@file.DiscName</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </main>

    <!-- Right Panel: Media Detail -->
    <aside class="media-detail-panel">
        <MediaFileDetail File="_selectedMediaFile" />
    </aside>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    [Inject] private MediaFileService MediaFileService { get; set; } = default!;
    private List<PerformerSummaryDto> _allPerformers = new();
    private PerformerDetailDto? _selectedPerformer;
    private MediaFile? _selectedMediaFile;
    private string _searchTerm = "";

    private bool _isEditing = false;
    private PerformerEditDto _editModel = new();

    protected override void OnInitialized()
    {
        _allPerformers = PerformerService.GetSummaries().ToList();
    }

    protected override void OnParametersSet() {
        if (Id.HasValue) {
            SelectPerformer(Id.Value);
        }
    }

    private List<PerformerSummaryDto> FilteredPerformers => 
        string.IsNullOrWhiteSpace(_searchTerm) 
            ? _allPerformers 
            : _allPerformers.Where(p => 
                p.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || 
                p.Aliases.Any(a => a.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
              ).ToList();

    private async Task SelectPerformer(int id)
    {
        _isEditing = false;
        _selectedPerformer = PerformerService.GetDetails(id);
        _selectedMediaFile = null;
        await JS.InvokeVoidAsync("scrollToTop", ".performer-detail-panel");
    }

    private void ViewMediaFile(int id)
    {
        _selectedMediaFile = MediaFileService.Get(id);
    }

    private string _newAlias = "";

    private void EnterEditMode()
    {
        if (_selectedPerformer == null) return;
        
        _editModel = new PerformerEditDto {
            Id = _selectedPerformer.Id,
            Name = _selectedPerformer.Name,
            Aliases = _selectedPerformer.Aliases.ToList(),
            HeadshotUrl = _selectedPerformer.HeadshotUrl,
            GalleryPhotoUrl = _selectedPerformer.GalleryPhotoUrl
        };
        _isEditing = true;
    }

    private void AddAlias() {
        if (!string.IsNullOrWhiteSpace(_newAlias) && !_editModel.Aliases.Contains(_newAlias, StringComparer.OrdinalIgnoreCase)) {
            _editModel.Aliases.Add(_newAlias.Trim());
            _newAlias = "";
        }
    }

    private async Task RemoveAlias(string alias) {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the alias '{alias}'?");
        if (confirm) {
            _editModel.Aliases.Remove(alias);
        }
    }

    private async Task UploadHeadshot(InputFileChangeEventArgs e) {
        var file = e.File;
        if (file != null) {
            var fileName = $"{_editModel.Name.Replace(" ", "_")}_headshot_{Guid.NewGuid().ToString().Substring(0,8)}{Path.GetExtension(file.Name)}";
            var savePath = PathResolver.GetPerformerHeadshotPath(fileName);
            using var stream = file.OpenReadStream(maxAllowedSize: 10485760); // 10MB
            using var fs = new FileStream(savePath, FileMode.Create);
            await stream.CopyToAsync(fs);
            
            _editModel.HeadshotUrl = fileName;
        }
    }

    private async Task UploadGalleryPhoto(InputFileChangeEventArgs e) {
        var file = e.File;
        if (file != null) {
            var fileName = $"{_editModel.Name.Replace(" ", "_")}_gallery_{Guid.NewGuid().ToString().Substring(0,8)}{Path.GetExtension(file.Name)}";
            var savePath = PathResolver.GetPerformerGalleryPath(fileName);
            using var stream = file.OpenReadStream(maxAllowedSize: 10485760);
            using var fs = new FileStream(savePath, FileMode.Create);
            await stream.CopyToAsync(fs);
            
            _editModel.GalleryPhotoUrl = fileName;
        }
    }

    private void CreateNewPerformer()
    {
        _selectedPerformer = null;
        _selectedMediaFile = null;
        
        _editModel = new PerformerEditDto {
            Id = 0, // 0 means new
            Name = "",
            Aliases = new List<string>()
        };
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _isEditing = false;
    }

    private void SaveChanges()
    {
        var result = PerformerService.Update(_editModel);
        if (result.Success)
        {
            _isEditing = false;
            // Refresh detail view
            _selectedPerformer = PerformerService.GetDetails(_editModel.Id);
            
            // Refresh master list summary if name changed
            var summary = _allPerformers.FirstOrDefault(p => p.Id == _editModel.Id);
            if (summary != null)
            {
                summary.Name = _editModel.Name;
                summary.HeadshotUrl = _editModel.HeadshotUrl;
                summary.Aliases = _editModel.Aliases.ToList();
            }
            else 
            {
                // New performer!
                _allPerformers.Add(new PerformerSummaryDto {
                    Id = _editModel.Id,
                    Name = _editModel.Name,
                    HeadshotUrl = _editModel.HeadshotUrl,
                    Aliases = _editModel.Aliases.ToList()
                });
                _allPerformers = _allPerformers.OrderBy(p => p.Name).ToList();
            }
        }
    }
}
