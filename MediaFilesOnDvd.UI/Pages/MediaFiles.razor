@page "/mediafiles"
@page "/mediafiles/{Id:int}"
@using MediaFilesOnDvd.Services.Dtos
@inject MediaFileService MediaFileService
@inject FileGenreService GenreService
@inject DiscService DiscService
@inject SeriesService SeriesService
@inject PathResolverService PathResolver
@inject NavigationManager Nav
@inject FileTagService TagService

<div class="@(IsModal ? "" : "media-browse")">
    @if (!IsModal)
    {
        <aside class="media-list-panel">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search media files..." @bind="_searchTerm" @bind:event="oninput" />
                <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="ToggleViewMode" title="Toggle View">
                    <i class="fas @(_isThumbnailView ? "fa-list" : "fa-th")"></i>
                </button>
            </div>
            @if (_filterSeriesId.HasValue)
            {
                <div class="active-filter p-2 border-bottom border-secondary d-flex justify-content-between align-items-center" style="background-color: var(--hover-color);">
                    <span class="text-white" style="font-size: 0.9em;"><i class="fas fa-filter text-muted me-2"></i>Series: <strong>@_filterSeriesName</strong></span>
                    <button class="btn btn-sm btn-link text-danger p-0 m-0" @onclick="ClearSeriesFilter" title="Clear Filter"><i class="fas fa-times"></i></button>
                </div>
            }
            <div class="media-scroll-list">
                <Virtualize Items="FilteredMediaFiles" Context="file" OverscanCount="10">
                    <div class="media-list-item @(file.Id == _currentFile?.Id ? "selected" : "") @(_isThumbnailView ? "thumb-mode" : "list-mode")" 
                         @onclick="() => SelectFile(file.Id)">
                        @if (_isThumbnailView)
                        {
                            <div class="media-thumb-result">
                                @if (!string.IsNullOrEmpty(file.ScreenshotUrl))
                                {
                                    <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(file.ScreenshotUrl))" />
                                }
                                else
                                {
                                    <i class="fas fa-file-video fa-2x"></i>
                                }
                            </div>
                        }
                        <div class="media-info-result">
                            <span class="file-name">@file.Name</span>
                            <span class="disc-name text-muted" style="font-size: 0.85em;">@file.DiscName</span>
                        </div>
                    </div>
                </Virtualize>
            </div>
        </aside>
    }

    <div class="media-file-view">
    <header class="view-header">
            @if (IsModal && _currentFile != null)
            {
                <h1 class="value-link" @onclick="NavigateToFullView" title="Open full page">@_currentFile.Name</h1>
            }
            else
            {
                <h1>@(_currentFile?.Name ?? "No File Selected")</h1>
            }
        <div class="mode-toggle">
            <label class="switch">
                <input type="checkbox" @bind="_isEditMode" @onclick="OnToggleEditMode" />
                <span class="slider round"></span>
            </label>
            <span class="mode-label">Edit Mode: @(_isEditMode ? "ON" : "OFF")</span>
        </div>
    </header>

    @if (_currentFile == null)
    {
        <div class="empty-state">
            <p>File not found or loading...</p>
        </div>
    }
    else
    {
        <div class="view-grid">
            <!-- Left Column: Metadata -->
            <div class="metadata-column">
                <div class="field-group">
                    <label>Genre</label>
                    @if (_isEditMode)
                    {
                        <select class="form-control" @bind="_currentFile.GenreId">
                            @foreach (var g in _allGenres)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="field-value">@_currentFile.GenreName</div>
                    }
                </div>

                <div class="field-group">
                    <label>Disc</label>
                    @if (_isEditMode)
                    {
                        <select class="form-control" @bind="_currentFile.DiscId">
                            @foreach (var d in _allDiscs)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                            <div class="field-value value-link" @onclick="() => NavigateTo('d', _currentFile.DiscId)">@_currentFile.DiscName</div>
                    }
                </div>

                <div class="field-group">
                    <label>Series</label>
                    @if (_isEditMode)
                    {
                        <select class="form-control" @bind="_currentFile.SeriesId">
                            <option value="">None</option>
                            @foreach (var s in _allSeries)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        @if (_currentFile.SeriesId.HasValue)
                        {
                            <div class="field-value value-link" @onclick="() => FilterBySeries(_currentFile.SeriesId.Value, _currentFile.SeriesName)">@_currentFile.SeriesName</div>
                        }
                        else
                        {
                            <div class="field-value">None</div>
                        }
                    }
                </div>

                <div class="field-group">
                    <label>Actors</label>
                    <div class="actor-list">
                        @foreach (var actor in _currentFile.Performers)
                        {
                            <div class="actor-item">
                                @if (_isEditMode)
                                {
                                    <div class="d-flex gap-2">
                                        <select class="form-control">
                                            <option>@actor.Name</option>
                                        </select>
                                        <button class="btn-icon text-danger"><i class="fas fa-trash"></i></button>
                                    </div>
                                }
                                else
                                {
                                    <span class="actor-name value-link" @onclick="() => NavigateTo('p', actor.Id)">@actor.Name</span>
                                }
                            </div>
                        }
                        @if (_isEditMode)
                        {
                            <div class="actor-item">
                                <select class="form-control">
                                    <option value="">-- Add Actor --</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>

                <div class="field-group">
                    <label>Notes</label>
                    @if (_isEditMode)
                    {
                        <textarea class="form-control" rows="4" @bind="_currentFile.Notes"></textarea>
                    }
                    else
                    {
                        <div class="field-value notes-text">@(_currentFile.Notes ?? "No notes.")</div>
                    }
                </div>

                @if (_isEditMode)
                {
                    <button class="btn-primary" @onclick="SaveChanges">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                }
            </div>

            <!-- Right Column: Media -->
            <div class="media-column">
                <div class="screenshot-large">
                    @if (_currentFile.ScreenshotUrls.Any())
                    {
                        <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(_currentFile.ScreenshotUrls.First()))" alt="" />
                    }
                    else
                    {
                        <div class="placeholder-img"><i class="fas fa-file-video fa-5x"></i></div>
                    }
                </div>
                <button class="btn-primary btn-block">
                    <i class="fas fa-image"></i> Add/Update Screenshot
                </button>

                <div class="field-group mt-4">
                    <label>Database ID</label>
                    <input type="text" class="form-control" value="@_currentFile.Id" readonly />
                </div>
            </div>
        </div>

        <footer class="view-footer">
            <h3>Keyword Tags</h3>
            <div class="tag-manager">
                @foreach (var tag in _currentFile.Tags)
                {
                    <span class="tag-pill">
                        @tag
                        @if (_isEditMode)
                        {
                            <i class="fas fa-times ml-2" style="cursor:pointer" @onclick="() => RemoveTag(tag)"></i>
                        }
                    </span>
                }
                @if (_isEditMode)
                {
                    <div class="add-tag">
                        <input type="text" placeholder="Add new tag..." @bind="_newTag" @bind:event="oninput" @onkeyup="HandleTagInput" />
                        <button class="btn-icon" @onclick="AddTag"><i class="fas fa-plus"></i></button>
                    </div>
                }
            </div>
        </footer>

        <!-- Navigation Overlay -->
        <div class="nav-overlay">
            <div class="nav-button-group">
                @if (!_isFirst)
                {
                    <button class="btn-nav" @onclick="GoToBeginning" title="First"><i class="fas fa-angles-left"></i></button>
                    <button class="btn-nav" @onclick="PreviousFile" title="Previous"><i class="fas fa-chevron-left"></i></button>
                }
                <span class="nav-info">@_currentFile.Id</span>
                @if (!_isLast)
                {
                    <button class="btn-nav" @onclick="NextFile" title="Next"><i class="fas fa-chevron-right"></i></button>
                    <button class="btn-nav" @onclick="GoToEnd" title="Last"><i class="fas fa-angles-right"></i></button>
                }
            </div>
        </div>
    }
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    [Parameter] public bool IsModal { get; set; }
    private MediaFileDetailDto? _currentFile;
    private static bool _isEditMode = false;

    private List<FileGenre> _allGenres = new();
    private List<Disc> _allDiscs = new();
    private List<Series> _allSeries = new();

    private bool _isFirst = false;
    private bool _isLast = false;
    private int? _firstId;
    private int? _lastId;

    private List<MediaFileSummaryDto> _allMediaFiles = new();
    private string _searchTerm = "";
    private bool _isThumbnailView = false;
    private int? _filterSeriesId = null;
    private string? _filterSeriesName = null;
    private string _newTag = "";

    private List<MediaFileSummaryDto> FilteredMediaFiles => _allMediaFiles
        .Where(f => !_filterSeriesId.HasValue || f.SeriesId == _filterSeriesId.Value)
        .Where(f => string.IsNullOrWhiteSpace(_searchTerm) || f.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || (f.DiscName != null && f.DiscName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    protected override void OnInitialized()
    {
        if (!IsModal)
        {
            _allMediaFiles = MediaFileService.GetSummaries().ToList();
        }
    }

    protected override void OnParametersSet()
    {
        LoadFile();
    }

    private void ToggleViewMode()
    {
        _isThumbnailView = !_isThumbnailView;
    }

    private void NavigateToFullView()
    {
        if (_currentFile != null)
        {
            Nav.NavigateTo($"/mediafiles/{_currentFile.Id}");
        }
    }

    private void FilterBySeries(int seriesId, string? seriesName)
    {
        _filterSeriesId = seriesId;
        _filterSeriesName = seriesName;
    }

    private void ClearSeriesFilter()
    {
        _filterSeriesId = null;
        _filterSeriesName = null;
    }

    private void SelectFile(int id)
    {
        if (IsModal)
        {
            Id = id;
            LoadFile();
        }
        else
        {
            Nav.NavigateTo($"/mediafiles/{id}", replace: true);
            Id = id;
            LoadFile();
        }
    }

    private void LoadFile()
    {
        _firstId = MediaFileService.GetFirstId();
        _lastId = MediaFileService.GetLastId();

        if (Id.HasValue)
        {
            _currentFile = MediaFileService.GetDetailDto(Id.Value);
        }
        else
        {
            if (_lastId.HasValue)
            {
                _currentFile = MediaFileService.GetDetailDto(_lastId.Value);
            }
        }

        if (_currentFile != null)
        {
            _isFirst = _currentFile.Id == _firstId;
            _isLast = _currentFile.Id == _lastId;
        }

        if (_isEditMode) LoadDropdowns();
    }

    private void OnToggleEditMode()
    {
        _isEditMode = !_isEditMode;
        if (_isEditMode) LoadDropdowns();
    }

    private void LoadDropdowns()
    {
        _allGenres = GenreService.Get().ToList();
        _allDiscs = DiscService.Get().ToList();
        _allSeries = SeriesService.Get().ToList();
    }

    private void SaveChanges()
    {
        if (_currentFile != null)
        {
            var result = MediaFileService.Update(_currentFile);
            if (result.Success)
            {
                // _isEditMode = false;
                // Re-fetch to ensure navigation properties (like GenreName) are updated
                _currentFile = MediaFileService.GetDetailDto(_currentFile.Id);
            }
        }
    }

    private void PreviousFile()
    {
        if (_currentFile != null)
        {
            var prevId = MediaFileService.GetPreviousId(_currentFile.Id);
            if (prevId.HasValue)
            {
                if (IsModal) { Id = prevId.Value; LoadFile(); }
                else { Nav.NavigateTo($"/mediafiles/{prevId.Value}"); }
            }
        }
    }

    private void NextFile()
    {
        if (_currentFile != null)
        {
            var nextId = MediaFileService.GetNextId(_currentFile.Id);
            if (nextId.HasValue)
            {
                if (IsModal) { Id = nextId.Value; LoadFile(); }
                else { Nav.NavigateTo($"/mediafiles/{nextId.Value}"); }
            }
        }
    }

    private void GoToBeginning()
    {
        if (_firstId.HasValue)
        {
            if (IsModal) { Id = _firstId.Value; LoadFile(); }
            else { Nav.NavigateTo($"/mediafiles/{_firstId.Value}"); }
        }
    }

    private void GoToEnd()
    {
        if (_lastId.HasValue)
        {
            if (IsModal) { Id = _lastId.Value; LoadFile(); }
            else { Nav.NavigateTo($"/mediafiles/{_lastId.Value}"); }
        }
    }

    private void NavigateTo(char type, int id) {
        var url = type switch {
            'd' => $"/discs/{id}",
            'p' => $"/performers/{id}",
            't' => $"/tags/{id}",
            _ => "/"
        };
        Nav.NavigateTo(url);
    }

    private void HandleTagInput(KeyboardEventArgs e) {
        if (e.Key == "Enter") {
            AddTag();
        }
    }

    private void AddTag()
    {
        if (string.IsNullOrWhiteSpace(_newTag) || _currentFile == null) return;

        var fileEntity = MediaFileService.Get(_currentFile.Id);
        if (fileEntity == null) return;

        var tagEntity = TagService.Get(_newTag);
        if (tagEntity == null) {
            var addResult = TagService.Add(_newTag);
            if (addResult.Success) {
                tagEntity = TagService.Get(_newTag);
            }
        }
        if (tagEntity != null) {
            var result = MediaFileService.AddTagToMediaFile(fileEntity, tagEntity);
            if (result.Success) {
                _newTag = "";
                LoadFile(); // Refresh to show new tag
            }
        }
    }

    private void RemoveTag(string tagName)
    {
        if (_currentFile == null) return;
        var fileEntity = MediaFileService.Get(_currentFile.Id);
        if (fileEntity == null) return;

        var tagEntity = TagService.Get(tagName);
        if (tagEntity != null) {
            var result = MediaFileService.RemoveTagFromMediaFile(fileEntity, tagEntity);
            if (result.Success) {
                LoadFile(); // Refresh to remove tag
            }
        }
    }
}
