@page "/mediafiles"
@page "/mediafiles/{Id:int}"
@using MediaFilesOnDvd.Services.Dtos
@inject MediaFileService MediaFileService
@inject FileGenreService GenreService
@inject DiscService DiscService
@inject SeriesService SeriesService
@inject PathResolverService PathResolver
@inject NavigationManager Nav

<div class="media-file-view">
    <header class="view-header">
        <div class="nav-controls">
            <button class="btn-icon" @onclick="PreviousFile"><i class="fas fa-chevron-left"></i></button>
            <h1>@(_currentFile?.Name ?? "No File Selected")</h1>
            <button class="btn-icon" @onclick="NextFile"><i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="mode-toggle">
            <label class="switch">
                <input type="checkbox" @bind="_isEditMode" @onclick="OnToggleEditMode" />
                <span class="slider round"></span>
            </label>
            <span class="mode-label">Edit Mode: @(_isEditMode ? "ON" : "OFF")</span>
        </div>
    </header>

    @if (_currentFile == null)
    {
        <div class="empty-state">
            <p>File not found or loading...</p>
        </div>
    }
    else
    {
        <div class="view-grid">
            <!-- Left Column: Metadata -->
            <div class="metadata-column">
                <div class="field-group">
                    <label>Genre</label>
                    @if (_isEditMode)
                    {
                        <select class="form-control" @bind="_currentFile.GenreId">
                            @foreach (var g in _allGenres)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="field-value">@_currentFile.GenreName</div>
                    }
                </div>

                <div class="field-group">
                    <label>Disc</label>
                    @if (_isEditMode)
                    {
                        <select class="form-control" @bind="_currentFile.DiscId">
                            @foreach (var d in _allDiscs)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="field-value">@_currentFile.DiscName</div>
                    }
                </div>

                <div class="field-group">
                    <label>Series</label>
                    @if (_isEditMode)
                    {
                        <select class="form-control" @bind="_currentFile.SeriesId">
                            <option value="">None</option>
                            @foreach (var s in _allSeries)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="field-value">@(_currentFile.SeriesName ?? "None")</div>
                    }
                </div>

                <div class="field-group">
                    <label>Actors</label>
                    <div class="actor-list">
                        @foreach (var actor in _currentFile.Performers)
                        {
                            <div class="actor-item">
                                @if (_isEditMode)
                                {
                                    <div class="d-flex gap-2">
                                        <select class="form-control">
                                            <option>@actor.Name</option>
                                        </select>
                                        <button class="btn-icon text-danger"><i class="fas fa-trash"></i></button>
                                    </div>
                                }
                                else
                                {
                                    <span class="actor-name">@actor.Name</span>
                                }
                            </div>
                        }
                        @if (_isEditMode)
                        {
                            <div class="actor-item">
                                <select class="form-control">
                                    <option value="">-- Add Actor --</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>

                <div class="field-group">
                    <label>Notes</label>
                    @if (_isEditMode)
                    {
                        <textarea class="form-control" rows="4" @bind="_currentFile.Notes"></textarea>
                    }
                    else
                    {
                        <div class="field-value notes-text">@(_currentFile.Notes ?? "No notes.")</div>
                    }
                </div>

                @if (_isEditMode)
                {
                    <button class="btn-primary" @onclick="SaveChanges">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                }
            </div>

            <!-- Right Column: Media -->
            <div class="media-column">
                <div class="screenshot-large">
                    @if (_currentFile.ScreenshotUrls.Any())
                    {
                        <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(_currentFile.ScreenshotUrls.First()))" alt="" />
                    }
                    else
                    {
                        <div class="placeholder-img"><i class="fas fa-file-video fa-5x"></i></div>
                    }
                </div>
                <button class="btn-primary btn-block">
                    <i class="fas fa-image"></i> Add/Update Screenshot
                </button>

                <div class="field-group mt-4">
                    <label>Database ID</label>
                    <input type="text" class="form-control" value="@_currentFile.Id" readonly />
                </div>
            </div>
        </div>

        <footer class="view-footer">
            <h3>Keyword Tags</h3>
            <div class="tag-manager">
                @foreach (var tag in _currentFile.Tags)
                {
                    <span class="tag-pill">
                        @tag
                        @if (_isEditMode)
                        {
                            <i class="fas fa-times ml-2"></i>
                        }
                    </span>
                }
                <div class="add-tag">
                    <input type="text" placeholder="Add new tag..." />
                    <button class="btn-icon"><i class="fas fa-plus"></i></button>
                </div>
            </div>
        </footer>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private MediaFileDetailDto? _currentFile;
    private static bool _isEditMode = false; // Static to persist across navigation

    private List<FileGenre> _allGenres = new();
    private List<Disc> _allDiscs = new();
    private List<Series> _allSeries = new();

    protected override void OnParametersSet()
    {
        LoadFile();
    }

    private void LoadFile()
    {
        if (Id.HasValue)
        {
            _currentFile = MediaFileService.GetDetailDto(Id.Value);
        }
        else
        {
            var latestId = MediaFileService.GetLatestId();
            if (latestId.HasValue)
            {
                _currentFile = MediaFileService.GetDetailDto(latestId.Value);
            }
        }

        if (_isEditMode) LoadDropdowns();
    }

    private void OnToggleEditMode()
    {
        _isEditMode = !_isEditMode;
        if (_isEditMode) LoadDropdowns();
    }

    private void LoadDropdowns()
    {
        _allGenres = GenreService.Get().ToList();
        _allDiscs = DiscService.Get().ToList();
        _allSeries = SeriesService.Get().ToList();
    }

    private void SaveChanges()
    {
        // Implementation for saving back to DB
        _isEditMode = false;
    }

    private void PreviousFile()
    {
        if (_currentFile != null)
        {
            var prevId = MediaFileService.GetPreviousId(_currentFile.Id);
            if (prevId.HasValue) Nav.NavigateTo($"/mediafiles/{prevId.Value}");
        }
    }

    private void NextFile()
    {
        if (_currentFile != null)
        {
            var nextId = MediaFileService.GetNextId(_currentFile.Id);
            if (nextId.HasValue) Nav.NavigateTo($"/mediafiles/{nextId.Value}");
        }
    }
}
