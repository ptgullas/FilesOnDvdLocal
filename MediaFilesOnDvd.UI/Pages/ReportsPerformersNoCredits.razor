@page "/reports/performers-no-credits"
@using MediaFilesOnDvd.Services
@using MediaFilesOnDvd.Services.Dtos
@inject PerformerService PerformerService

<div class="reports-page p-4">
    <h1 class="mb-4">Performers Without Credits</h1>

    @if (_performers == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!_performers.Any())
    {
        <p>All performers have credits!</p>
    }
    else
    {
        <div class="mb-3">
            <span class="">Found <strong>@_performers.Count</strong> performers without any associated MediaFiles.</span>
        </div>

        <div class="performer-list">
            @foreach (var performer in _performers)
            {
                <div class="card bg-dark text-light border-secondary mb-2">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <a href="/performers/@performer.Id" class="text-accent text-decoration-none">@performer.Name</a>
                        </h5>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PerformerSummaryDto>? _performers;

    protected override void OnInitialized()
    {
        _performers = PerformerService.GetSummaries()
            .Where(p => p.CreditCount == 0)
            .ToList();
    }
}
