@page "/settings"
@using MediaFilesOnDvd.Services
@inject SettingsService SettingsService
@inject IJSRuntime JS

<div class="settings-page p-4">
    <h1 class="mb-4">Settings</h1>

    <div class="card bg-dark text-light border-secondary mb-4" style="max-width: 600px;">
        <div class="card-body">
            <h5 class="card-title text-accent">Screensaver Settings</h5>
            <div class="form-group mb-3">
                <label for="screensaverTimeout" class="form-label">Screensaver Timeout (seconds)</label>
                <div class="input-group">
                    <input type="number" id="screensaverTimeout" class="form-control bg-dark text-light border-secondary" @bind="_settings.ScreensaverTimeoutSeconds" min="10" step="10" />
                    <span class="input-group-text bg-dark text-light border-secondary">seconds</span>
                </div>
                <small class="text-muted">How long the application must be idle before the screensaver starts.</small>
            </div>

            <h5 class="card-title text-accent mt-4">Theme Settings</h5>
            <div class="form-group mb-4">
                <label for="accentColor" class="form-label">Accent Color</label>
                <div class="input-group" style="max-width: 200px;">
                    <input type="color" id="accentColor" class="form-control form-control-color bg-dark border-secondary p-1" @bind="_settings.AccentColor" style="max-width: 60px; height: 38px;" />
                    <input type="text" class="form-control bg-dark text-light border-secondary" @bind="_settings.AccentColor" />
                </div>
                <small class="text-muted">Choose the primary accent color for the app.</small>
            </div>
            
            <button class="btn btn-primary" @onclick="SaveSettings">Save Settings</button>
        </div>
    </div>
    
    @if (_showSuccessMessage)
    {
        <div class="alert alert-success" style="max-width: 600px;">
            Settings saved successfully!
        </div>
    }
</div>

@code {
    private UserSettings _settings = new();
    private bool _showSuccessMessage = false;

    protected override void OnInitialized()
    {
        _settings = SettingsService.Get();
    }

    private async Task SaveSettings()
    {
        SettingsService.SaveSettings(_settings);
        _showSuccessMessage = true;
        
        await Task.Delay(3000);
        _showSuccessMessage = false;
        StateHasChanged();
    }
}
