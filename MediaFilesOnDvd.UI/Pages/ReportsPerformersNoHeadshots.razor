@page "/reports/performers-no-headshots"
@using MediaFilesOnDvd.Services
@using MediaFilesOnDvd.Services.Dtos
@inject PerformerService PerformerService

<div class="reports-page p-4">
    <h1 class="mb-4">Performers Without Headshots</h1>

    @if (_performers == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!_performers.Any())
    {
        <p>All performers have headshots!</p>
    }
    else
    {
        <div class="mb-3 d-flex align-items-center">
            @if (_performers.Count == 1)
            {
                <span class="me-3">Found 1 performer without headshots.</span>
            }
            else {
                if (_filterHasCredits)
                {
                    <span class="me-3">Found <strong>@FilteredPerformers.Count()</strong> performers without headshots WITH credits.</span>
                }
                else
                {
                    <span class="me-3">Found <strong>@_performers.Count</strong> performers without headshots.</span>
                }
            }

            <div class="form-check form-switch ms-3">
                <input class="form-check-input" type="checkbox" id="filterHasCredits" @bind="FilterHasCredits" />
                <label class="form-check-label" for="filterHasCredits">Has Credits (Subreport)</label>
            </div>
        </div>

        <div class="performer-list">
            @foreach (var performer in FilteredPerformers)
            {
                <div class="card bg-dark text-light border-secondary mb-2">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <span class="performer-name text-accent text-decoration-none" @onclick="() => OpenModal(performer.Id)">@performer.Name</span>
                        </h5>
                    </div>
                    @if (_filterHasCredits && performer.MediaFiles.Any())
                    {
                        <div class="card-footer bg-dark border-top-0 pt-0 pb-3 ps-5">
                            <div class="d-flex flex-column gap-2">
                                @foreach (var mf in performer.MediaFiles)
                                {
                                    <div class="mediafile-item text-muted" @onclick="() => OpenMediaFileModal(mf.Id)">
                                        <i class="fas fa-file-video me-2 mediafile-icon"></i>@mf.Name
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<MediaFilesOnDvd.UI.Shared.PerformerModal @ref="_performerModal" />
<MediaFilesOnDvd.UI.Shared.MediaFileModal @ref="_mediaFileModal" />

@code {
    private List<PerformerReportDto>? _performers;
    private bool _filterHasCredits = false;
    private MediaFilesOnDvd.UI.Shared.PerformerModal? _performerModal;
    private MediaFilesOnDvd.UI.Shared.MediaFileModal? _mediaFileModal;

    private bool FilterHasCredits
    {
        get => _filterHasCredits;
        set
        {
            if (_filterHasCredits != value)
            {
                _filterHasCredits = value;
                StateHasChanged();
            }
        }
    }

    protected override void OnInitialized()
    {
        _performers = PerformerService.GetForReport()
            .Where(p => string.IsNullOrWhiteSpace(p.HeadshotUrl))
            .ToList();
    }

    private void OpenModal(int id)
    {
        _performerModal?.Open(id);
    }

    private void OpenMediaFileModal(int mfId)
    {
        _mediaFileModal?.Open(mfId);
    }

    private IEnumerable<PerformerReportDto> FilteredPerformers => 
        _filterHasCredits 
            ? _performers?.Where(p => p.CreditCount > 0) ?? Enumerable.Empty<PerformerReportDto>()
            : _performers ?? Enumerable.Empty<PerformerReportDto>();
}
