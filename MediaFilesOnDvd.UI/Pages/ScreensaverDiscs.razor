@using MediaFilesOnDvd.Services.Dtos
@using MediaFilesOnDvd.Data.Entities
@using MediaFilesOnDvd.Services
@inject DiscService DiscService
@inject MediaFileService MediaFileService
@inject PathResolverService PathResolver

<div class="screensaver-fullscreen">
    <div class="screensaver-headshot">
        <div class="screensaver-headshot-info">
            <h1 class="screensaver-title">
                <i class="fas fa-compact-disc me-3"></i>@_selectedDisc?.Name
            </h1>
            @if (_discMediaFiles.Any())
            {
                <h2 class="screensaver-subtitle">@_discMediaFiles.Count Files</h2>
            }
        </div>
    </div>
    <div class="screensaver-collage">
        @if (_row1Items.Any())
        {
            <div class="collage-track @(_row1ScrollsLeft ? "scroll-left" : "scroll-right")">
                @foreach (var loop in new[] { 1, 2 })
                {
                    @foreach (var item in _row1Items)
                    {
                        if (item.IsBlank)
                        {
                            <div class="collage-item blank-item" style="background: transparent; box-shadow: none; width: 426px;"></div>
                        }
                        else
                        {
                            <div class="collage-item">
                                <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(item.ImageUrl))" />
                                <div class="collage-label">@item.Label</div>
                            </div>
                        }
                    }
                }
            </div>
        }
        @if (_row2Items.Any())
        {
            <div class="collage-track @(_row1ScrollsLeft ? "scroll-right" : "scroll-left")">
                @foreach (var loop in new[] { 1, 2 })
                {
                    @foreach (var item in _row2Items)
                    {
                        if (item.IsBlank)
                        {
                            <div class="collage-item blank-item" style="background: transparent; box-shadow: none; width: 426px;"></div>
                        }
                        else
                        {
                            <div class="collage-item">
                                <img src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(item.ImageUrl))" />
                                <div class="collage-label">@item.Label</div>
                            </div>
                        }
                    }
                }
            </div>
        }
    </div>
</div>

@implements IDisposable

@code {
    private List<Disc> _allDiscs = new();
    private Disc? _selectedDisc;
    private List<MediaFileSummaryDto> _discMediaFiles = new();

    private System.Threading.Timer? _screensaverTimer;

    private class CollageItem
    {
        public string ImageUrl { get; set; } = "";
        public string Label { get; set; } = "";
        public bool IsBlank { get; set; }
    }

    private List<CollageItem> _row1Items = new();
    private List<CollageItem> _row2Items = new();
    private bool _row1ScrollsLeft = true;

    protected override void OnInitialized()
    {
        _allDiscs = DiscService.Get()
            .Where(d => d.WalletId == 1)
            .ToList();
        _screensaverTimer = new System.Threading.Timer(ScreensaverTick, null, 0, 8000);
    }

    private void ScreensaverTick(object? state)
    {
        if (_allDiscs.Count > 0)
        {
            InvokeAsync(() => {
                Disc? validDisc = null;
                List<MediaFileSummaryDto> validFiles = new();
                int attempts = 0;
                while (validDisc == null && attempts < 20)
                {
                    var randomIdx = new Random().Next(_allDiscs.Count);
                    var randomDisc = _allDiscs[randomIdx];
                    var files = MediaFileService.GetSummaries().Where(m => m.DiscName == randomDisc.Name && !string.IsNullOrEmpty(m.ScreenshotUrl)).ToList();
                    if (files.Any())
                    {
                        validDisc = randomDisc;
                        validFiles = files;
                    }
                    attempts++;
                }

                if (validDisc != null)
                {
                    _selectedDisc = validDisc;
                    _discMediaFiles = validFiles;

                    var allItems = validFiles.Select(f => new CollageItem { ImageUrl = f.ScreenshotUrl, Label = f.Name }).ToList();

                    _row1Items.Clear();
                    _row2Items.Clear();
                    for (int i = 0; i < allItems.Count; i++)
                    {
                        if (i % 2 == 0) _row1Items.Add(allItems[i]);
                        else _row2Items.Add(allItems[i]);
                    }

                    while (_row1Items.Count > 0 && _row1Items.Count < 4)
                    {
                        _row1Items.Add(new CollageItem { IsBlank = true });
                    }
                    while (_row2Items.Count > 0 && _row2Items.Count < 4)
                    {
                        _row2Items.Add(new CollageItem { IsBlank = true });
                    }

                    _row1ScrollsLeft = new Random().Next(2) == 0;

                    StateHasChanged();
                }
            });
        }
    }

    public void Dispose()
    {
        _screensaverTimer?.Dispose();
    }
}
