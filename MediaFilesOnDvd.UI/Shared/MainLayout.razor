
@inherits LayoutComponentBase
@using MediaFilesOnDvd.Services
@inject SettingsService SettingsService
@inject IJSRuntime JS
@implements IDisposable

<div class="page">
    <div class="@SidebarCssClass">
        <NavMenu OnToggle="ToggleSidebar" IsCollapsed="@_sidebarCollapsed" />
    </div>

    <main>
        <header class="top-header">
            <div class="header-left">
                @if (_sidebarCollapsed)
                {
                    <button class="hamburger-btn" @onclick="ToggleSidebar">
                        <i class="fas fa-bars"></i>
                    </button>
                }
            </div>
            
            <div class="header-center">
                <SectionOutlet SectionName="header-center" />
            </div>

            <div class="header-right">
                <!-- Screensaver Toggle -->
                <button class="btn btn-link text-white header-icon-link border-0 p-0 me-3" @onclick="ToggleScreensaver" title="Toggle Screensaver">
                    <i class="fas @(IsScreensaverMode ? "fa-stop-circle text-danger" : "fa-tv") fa-lg"></i>
                </button>

                <!-- Home Link -->
                <NavLink href="/" class="header-icon-link me-3" Match="NavLinkMatch.All" title="Home">
                    <i class="fas fa-home fa-lg"></i>
                </NavLink>

                <!-- Profile/Settings placeholder -->
                <NavLink href="/settings" class="header-icon-link" title="Settings">
                    <i class="fas fa-cog fa-lg"></i>
                </NavLink>
            </div>
        </header>

        <article class="content">
            <CascadingValue Value="this">
                @Body
            </CascadingValue>
        </article>

        @if (IsScreensaverMode)
        {
            <div class="screensaver-controls-overlay" 
                 @ref="_screensaverOverlay" 
                 tabindex="0" 
                 @onmousemove="HandleScreensaverMouseMove" 
                 @onkeydown="HandleScreensaverKeyDown" 
                 style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 10000; outline: none;">
                 
                @if (ShowScreensaverControls)
                {
                    <button class="btn btn-outline-light" 
                            style="position: absolute; top: 20px; right: 20px; z-index: 10001; background: rgba(0,0,0,0.5); font-size: 1.2rem;" 
                            @onclick="ToggleScreensaver" title="Exit Screensaver">
                        <i class="fas fa-times me-2"></i>Exit
                    </button>
                }
            </div>
        }
    </main>
</div>

@code {
    private bool _sidebarCollapsed = false;
    public bool IsScreensaverMode { get; private set; }
    public bool ShowScreensaverControls { get; private set; }
    private System.Threading.Timer? _controlsTimer;
    private ElementReference _screensaverOverlay;
    private bool _focusOverlayNextRender = false;
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    private string SidebarCssClass => _sidebarCollapsed ? "sidebar collapsed" : "sidebar";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            SettingsService.OnSettingsChanged += HandleSettingsChanged;
            var timeout = SettingsService.Get().ScreensaverTimeoutSeconds;
            await JS.InvokeVoidAsync("initializeIdleTimer", _dotNetRef, timeout);
        }

        if (_focusOverlayNextRender)
        {
            _focusOverlayNextRender = false;
            try { await _screensaverOverlay.FocusAsync(); } catch { }
        }
    }

    [JSInvokable]
    public void OnIdleTimeout()
    {
        if (!IsScreensaverMode)
        {
            ToggleScreensaver();
        }
    }

    private async void HandleSettingsChanged()
    {
        var timeout = SettingsService.Get().ScreensaverTimeoutSeconds;
        await JS.InvokeVoidAsync("updateIdleTimeout", timeout);
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    public void CollapseSidebar()
    {
        if (!_sidebarCollapsed)
        {
            _sidebarCollapsed = true;
            StateHasChanged();
        }
    }

    public void ToggleScreensaver()
    {
        IsScreensaverMode = !IsScreensaverMode;
        if (IsScreensaverMode)
        {
            ShowScreensaverControls = false;
            _focusOverlayNextRender = true;
        }
        StateHasChanged();
    }

    private void HandleScreensaverMouseMove()
    {
        if (!IsScreensaverMode) return;
        ShowScreensaverControls = true;
        StateHasChanged();
        
        _controlsTimer?.Dispose();
        _controlsTimer = new System.Threading.Timer(_ => 
        {
            ShowScreensaverControls = false;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    private void HandleScreensaverKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            IsScreensaverMode = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        SettingsService.OnSettingsChanged -= HandleSettingsChanged;
        _dotNetRef?.Dispose();
        _controlsTimer?.Dispose();
    }
}
