@inject NavigationManager Nav
@inject PathResolverService PathResolver

<div class="media-file-detail">
    @if (File == null)
    {
        <div class="no-selection">
            <i class="fas fa-info-circle"></i>
            <p>Select a file to view details</p>
        </div>
    }
    else
    {
        <div class="detail-container">
            <div class="screenshot-preview">
                @if (File.Screenshots.Any())
                {
                    <MediaFilesOnDvd.UI.Shared.HoverImage Src="@PathResolver.GetImageAsBase64(PathResolver.GetMediaScreenshotPath(File.Screenshots.First().Url))" Alt="@File.Name" />
                }
                else
                {
                    <div class="placeholder-img"><i class="fas fa-file-video fa-4x"></i></div>
                }
            </div>

            <div class="info-group">
                <label>Filename</label>
                <a class="value-link" @onclick="OpenMediaFileModal">@File.Name</a>
            </div>

            <div class="info-group">
                <label>Disc</label>
                <a class="value-link" @onclick="() => NavigateTo('d', File.DiscId)">@File.Disc?.Name</a>
            </div>

            <div class="info-group">
                <label>Performers</label>
                <div class="list-values">
                    @foreach (var p in File.Performers)
                    {
                        <span class="value-link" @onclick="() => OpenPerformerModal(p.Id)">@p.Name</span>
                    }
                </div>
            </div>

            <div class="info-group">
                <label>Tags</label>
                <div class="tag-list">
                    @foreach (var t in File.Tags)
                    {
                        <span class="tag-pill" @onclick="() => NavigateTo('t', t.Id)">@t.Name</span>
                    }
                </div>
            </div>
        </div>
    }
</div>

<MediaFilesOnDvd.UI.Shared.PerformerModal @ref="_performerModal" />
<MediaFilesOnDvd.UI.Shared.MediaFileModal @ref="_mediaFileModal" />


@code {
    [Parameter] public MediaFile? File { get; set; }
    [Parameter] public EventCallback<int> OnPerformerClicked { get; set; }
    
    private MediaFilesOnDvd.UI.Shared.PerformerModal? _performerModal;
    private MediaFilesOnDvd.UI.Shared.MediaFileModal? _mediaFileModal;

    private async Task OpenPerformerModal(int id)
    {
        if (OnPerformerClicked.HasDelegate)
        {
            await OnPerformerClicked.InvokeAsync(id);
        }
        else
        {
            _performerModal?.Open(id);
        }
    }

    private void OpenMediaFileModal() {
        _mediaFileModal?.Open(File.Id);
    }


    private void NavigateTo(char type, int id)
    {
        var url = type switch
        {
            'd' => $"/discs/{id}",
            'p' => $"/performers/{id}",
            't' => $"/tags/{id}",
            _ => "/"
        };
        Nav.NavigateTo(url);
    }
}
